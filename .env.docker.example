# 复制为 .env 后由 docker compose 读取（可选）
# cp .env.docker.example .env

POSTGRES_USER=mech
POSTGRES_PASSWORD=mech_secret_change_me
POSTGRES_DB=mechanical_ai

# 若本机已占用端口可改
API_PORT=8010
FRONTEND_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# 至少 16 字符；生产务必 openssl rand -hex 32
JWT_SECRET=docker-dev-change-use-openssl-rand-hex-32
