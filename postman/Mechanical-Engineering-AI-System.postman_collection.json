            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/diagnosis/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "diagnosis", "submit"]
            }
          },
          "response": []
        }
      ]
    },
