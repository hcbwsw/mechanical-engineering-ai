{
  "info": {
    "name": "机械工程AI诊断系统 - 完整演示集合",
    "description": "包含5个真实工业场景的API测试集合，支持直接导入Postman/Insomnia",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔧 系统检查",
      "item": [
        {
          "name": "健康检查",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "验证系统运行状态"
          },
          "response": []
        },
        {
          "name": "系统指标",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/system/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "system", "metrics"]
            },
            "description": "查看CPU、内存、缓存等系统指标"
          },
          "response": []
        }
      ]
    },
    {
      "name": "👤 用户认证",
      "item": [
        {
          "name": "用户注册",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('username', 'engineer_' + Date.now());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"engineer_test\",\n  \"password\": \"password123\",\n  \"email\": \"engineer@company.com\",\n  \"role\": \"maintenance_engineer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "用户登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('token', jsonData.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"engineer_test\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "⚡ 场景1: 轴承故障诊断",
      "item": [
        {
          "name": "提交诊断 - 轴承故障",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"BEARING-001\",\n  \"device_name\": \"生产线主轴承\",\n  \"device_type\": \"rolling_bearing\",\n  \"location\": \"Assembly Line A\",\n  \"measurement_data\": {\n    \"vibration_amplitude_mm\": 0.85,\n    \"vibration_frequency_hz\": 1250,\n    \"temperature_celsius\": 68,\n    \"noise_level_db\": 82,\n    \"rotational_speed_rpm\": 1500,\n    \"lubrication_pressure_bar\": 1.2\n  },\n  \"description\": \"轴承振动异常，温度升高\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/diagnosis/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "diagnosis", "submit"]
            }
          },
          "response": []
        },
        {
          "name": "查询诊断结果 - 轴承",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/diagnosis/BEARING-001",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "diagnosis", "BEARING-001"]
            }
          },
          "response": []
        }
      ]
    },
    {
